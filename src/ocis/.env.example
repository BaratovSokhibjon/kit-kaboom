# ownCloud Infinite Scale (oCIS)
OCIS_VERSION=latest
OCIS_PORT=25004

# Public URL - must match the domain users access oCIS from
OCIS_URL=https://files.example.com

# Set to false when TLS is terminated at a reverse proxy (nginx, Traefik, Caddy)
PROXY_TLS=false
OCIS_INSECURE=false

# Admin credentials (set on first init)
IDM_ADMIN_PASSWORD=OCIS_ADMIN_PASSWORD123
IDM_CREATE_DEMO_USERS=false

# Secrets - generate with: openssl rand -hex 32
OCIS_JWT_SECRET=CHANGE_ME_JWT_SECRET
OCIS_MACHINE_AUTH_API_KEY=CHANGE_ME_MACHINE_AUTH_API_KEY
OCIS_TRANSFER_SECRET=CHANGE_ME_TRANSFER_SECRET
OCIS_SYSTEM_USER_API_KEY=CHANGE_ME_SYSTEM_USER_API_KEY

# Enable basic auth for WebDAV clients (e.g. desktop sync apps)
PROXY_ENABLE_BASIC_AUTH=true

# Logging
OCIS_LOG_LEVEL=error
OCIS_LOG_COLOR=false

# Storage locations
OCIS_CONFIG_LOCATION=../../volumes/storage/ocis/config
OCIS_DATA_LOCATION=../../volumes/storage/ocis/data


# --------------------------------------
# -----------  ONLYOFFICE  -------------
# --------------------------------------

ONLYOFFICE_VERSION=latest
ONLYOFFICE_PORT=25005

# Public URL of the ONLYOFFICE DocumentServer (where the browser loads the editor)
ONLYOFFICE_URL=https://onlyoffice.example.com

# JWT secret shared between ONLYOFFICE and the collaboration service
# generate with: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE_JWT_SECRET

# Storage locations
ONLYOFFICE_LOG_LOCATION=../../volumes/storage/onlyoffice/logs
ONLYOFFICE_DATA_LOCATION=../../volumes/storage/onlyoffice/data
ONLYOFFICE_LIB_LOCATION=../../volumes/storage/onlyoffice/lib
ONLYOFFICE_DB_LOCATION=../../volumes/storage/onlyoffice/db

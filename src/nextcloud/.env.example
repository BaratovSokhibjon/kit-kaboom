# Nextcloud
NEXTCLOUD_PORT=25003

NEXTCLOUD_DATA_LOCATION=../../volumes/storage/nextcloud/data

# Trusted domains (space-separated list of domains/IPs that can access Nextcloud)
NEXTCLOUD_TRUSTED_DOMAINS=localhost nextcloud.example.com

# Admin credentials (only used on first-run setup)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=NEXTCLOUD_ADMIN_PASSWORD123

# PHP limits
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=512M


# --------------------------------------
# ---------------  DATABASE  -----------
# --------------------------------------

NEXTCLOUD_DB_HOST=nextcloud-db
NEXTCLOUD_DB_USER=nextcloud_admin
NEXTCLOUD_DB_PASSWORD=NEXTCLOUD_DB_PASSWORD123
NEXTCLOUD_DB_DATABASE=nextcloud_db
NEXTCLOUD_DB_DATA_LOCATION=../../volumes/storage/nextcloud-db/data


# --------------------------------------
# ---------------  REDIS  ---------------
# --------------------------------------

NEXTCLOUD_REDIS_HOST=nextcloud-redis
NEXTCLOUD_REDIS_PORT=6380
NEXTCLOUD_REDIS_DATA_LOCATION=../../volumes/storage/nextcloud-redis/data


# --------------------------------------
# ---------------  EMAIL  ---------------
# --------------------------------------

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_NAME=support@example.com
# SMTP_PASSWORD=SUPPORT_EMAIL_PASSWORD123
# MAIL_FROM_ADDRESS=noreply
# MAIL_DOMAIN=example.com


# --------------------------------------
# ----------  REVERSE PROXY  -----------
# --------------------------------------

# Uncomment when running behind a reverse proxy
# TRUSTED_PROXIES=172.16.0.0/12
# OVERWRITEHOST=nextcloud.example.com
# OVERWRITEPROTOCOL=https
